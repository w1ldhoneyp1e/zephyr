{
  "name": "automat-vm",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "bin": {
    "vm": "dist/main.js",
    "zephyr": "dist/zephyrMain.js"
  },
  "scripts": {
    "dev": "ts-node --project tsconfig.json vm/main.ts",
    "dev:zephyr": "ts-node --project tsconfig.json zephyr/main.ts",
    "build": "tsup",
    "build:tsc": "tsc --project tsconfig.json",
    "lint": "eslint vm zephyr --ext .ts --fix",
    "test:features": "ts-node --project tsconfig.json tests/runFeatureTests.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "typescript": "^6.0.2",
    "@eslint/compat": "^1.2.4",
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.14.0",
    "@stylistic/eslint-plugin": "^2.12.1",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9",
    "eslint-config-next": "15.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-newlines": "^1.4.0",
    "eslint-plugin-jsonc": "^2.18.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-sort-exports": "^0.9.1",
    "eslint-plugin-yml": "^1.15.0",
    "typescript-eslint": "^8.14.0"
  }
}
