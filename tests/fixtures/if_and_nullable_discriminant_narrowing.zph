class Dog {
	kind: string;
	value: number;

	constructor(value: number) {
		self.kind = "dog";
		self.value = value;
	}

	fn bark(): number {
		return self.value;
	}
}

class Cat {
	kind: string;
	value: number;

	constructor(value: number) {
		self.kind = "cat";
		self.value = value;
	}

	fn meow(): number {
		return self.value;
	}
}

fn speak(animal: Dog | Cat | null): number {
	if (animal != null && animal.kind == "dog") {
		return animal.bark();
	}
	return 0;
}

return speak(Dog(37));
