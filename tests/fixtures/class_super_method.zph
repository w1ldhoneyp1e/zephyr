class Animal {
	public age: number;
	constructor(age: number) {
		self.age = age;
	}

	fn grow(): number {
		self.age = self.age + 1;
		return self.age;
	}
}

class Dog extends Animal {
	public weight: number;
	constructor(age: number, weight: number) {
		super(age);
		self.weight = weight;
	}

	fn grow(): number {
		return super.grow() + self.weight;
	}
}

var dog: Dog = Dog(2, 3);
return dog.grow();
