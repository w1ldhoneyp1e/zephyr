{
  "name": "zephyr-language",
  "displayName": "Zephyr Language",
  "description": "Syntax highlighting and editor basics for Zephyr source files.",
  "version": "0.0.1",
  "publisher": "zephyr",
  "main": "./out/extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onLanguage:zephyr"
  ],
  "scripts": {
    "compile": "tsc --project tsconfig.json",
    "watch": "tsc --project tsconfig.json --watch",
    "package": "yarn compile && vsce package --allow-missing-repository --no-yarn --no-dependencies --skip-license",
    "install:local": "code --install-extension zephyr-language-0.0.1.vsix --force"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "zephyr",
        "aliases": [
          "Zephyr",
          "zephyr"
        ],
        "extensions": [
          ".zph"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "zephyr",
        "scopeName": "source.zephyr",
        "path": "./syntaxes/zephyr.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "zephyr",
        "path": "./snippets/zephyr.code-snippets"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.6.3",
    "typescript": "^6.0.2"
  }
}
